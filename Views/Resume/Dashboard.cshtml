@model List<ResumeProject.Models.Resume>
@{
    ViewData["Title"] = "My Resumes - ResumeAI";
    Layout = "_Layout";
    string userName = ViewBag.UserName ?? "User";
}

<nav class="navbar">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <span class="logo-icon">📄</span> ResumeAI
    </a>
    <ul class="navbar-nav">
        <li><a asp-controller="Resume" asp-action="Dashboard" class="active">Dashboard</a></li>
        <li><a asp-controller="Resume" asp-action="Analyze">Analyze PDF</a></li>
        <li><a asp-controller="InterviewPrep" asp-action="Index">Interview Prep</a></li>
    </ul>
    <div class="navbar-actions">
        <span style="color:var(--text-secondary);font-size:14px;">👤 @userName</span>
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-sm" style="border-radius:8px; padding:8px 16px;">→ Logout</button>
        </form>
    </div>
</nav>

<div style="padding: 40px 48px;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:32px;">
        <div>
            <h1 style="font-size:28px; font-weight:700;">My Resumes</h1>
            <p style="color:var(--text-secondary); font-size:14px; margin-top:4px;">Manage and edit your resumes</p>
        </div>
        <form asp-action="CreateResume" method="post" style="margin:0;">
            @Html.AntiForgeryToken()
            <button type="submit" id="createNewBtn" class="btn btn-outline" style="border-radius:10px; background:#fff; color:#111; border:none; font-weight:600; padding:12px 24px;">
                + Create New
            </button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center; padding:80px 0; color:var(--text-muted);">
            <div style="font-size:48px; margin-bottom:16px;">📄</div>
            <p style="font-size:16px; margin-bottom:20px;">No resumes yet. Create your first one!</p>
            <form asp-action="CreateResume" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">+ Create Resume</button>
            </form>
        </div>
    }
    else
    {
        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap:20px;">
            @foreach (var resume in Model)
            {
                <div class="resume-card" style="background:var(--bg-card); border:1px solid var(--border); border-radius:16px; padding:24px; display:flex; flex-direction:column; gap:12px; transition:box-shadow 0.2s;">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between;">
                        <div style="width:44px; height:44px; background:rgba(139,92,246,0.2); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px;">📄</div>
                        <span style="color:var(--text-muted); font-size:12px;">@resume.UpdatedAt.ToString("M/d/yyyy")</span>
                    </div>

                    <div>
                        <h3 style="font-size:17px; font-weight:700; margin-bottom:6px;">
                            @(string.IsNullOrEmpty(resume.FirstName) ? "New Resume" : resume.FirstName + " " + resume.LastName)
                        </h3>
                        @if (!string.IsNullOrEmpty(resume.ProfessionalSummary))
                        {
                            <p style="color:var(--text-secondary); font-size:13px; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                @resume.ProfessionalSummary
                            </p>
                        }
                        else
                        {
                            <p style="color:var(--text-muted); font-size:13px; font-style:italic;">No summary yet...</p>
                        }
                    </div>

                    <div style="display:flex; align-items:center; gap:8px; margin-top:4px;">
                        <a asp-action="PersonalDetails" asp-route-id="@resume.Id"
                           class="btn btn-ghost btn-sm" style="flex:1; justify-content:center; border-radius:8px; border:1px solid var(--border);">
                            ✏️ Edit
                        </a>
                        <form asp-controller="Resume" asp-action="DeleteResume" method="post" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@resume.Id" />
                            <button type="submit" class="btn btn-danger btn-sm delete-btn" style="padding:8px 12px; border-radius:8px;">🗑</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    document.querySelectorAll('.resume-card').forEach(card => {
        card.addEventListener('mouseenter', () => card.style.boxShadow = '0 0 0 2px var(--purple)');
        card.addEventListener('mouseleave', () => card.style.boxShadow = 'none');
    });

    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            if (!confirm('Are you sure you want to delete this resume? This action cannot be undone.')) {
                e.preventDefault();
            }
        });
    });
</script>
}
