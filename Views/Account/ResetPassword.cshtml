@model ResumeProject.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password - ResumeAI";
    Layout = "_Layout";
}

<nav class="auth-navbar">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <span class="logo-icon">📄</span>
        ResumeAI
    </a>
    <div class="navbar-actions">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline btn-sm">Login</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get Started</a>
    </div>
</nav>

<div class="auth-page" style="padding-top:80px;">
    <div class="auth-card">
        <h1 class="auth-title">Reset Password</h1>
        <p class="auth-subtitle">Enter your new password below</p>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" class="form-control" type="password" placeholder="New password" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm new password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px; background:#fff; color:#111;">Reset Password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
