@model ResumeProject.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password - ResumeAI";
    Layout = "_Layout";
}

<nav class="auth-navbar">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <span class="logo-icon">📄</span>
        ResumeAI
    </a>
    <div class="navbar-actions">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline btn-sm">Login</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get Started</a>
    </div>
</nav>

<div class="auth-page" style="padding-top:80px;">
    <div class="auth-card">
        <h1 class="auth-title">Forgot Password</h1>
        <p class="auth-subtitle">Enter your email to reset your password</p>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px; background:#fff; color:#111;">Submit</button>
        </form>

        <div class="auth-link">
            Remember your password? <a asp-action="Login">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
