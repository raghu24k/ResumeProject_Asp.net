@model ResumeProject.Models.RegisterViewModel
@{
    ViewData["Title"] = "Create Account - ResumeAI";
    Layout = "_Layout";
}

<nav class="auth-navbar">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <span class="logo-icon">📄</span>
        ResumeAI
    </a>
    <div class="navbar-actions">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline btn-sm">Login</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get Started</a>
    </div>
</nav>

<div class="auth-page" style="padding-top:80px;">
    <div class="auth-card">
        <h1 class="auth-title">Create Account</h1>
        <p class="auth-subtitle">Join thousands of job seekers</p>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="John Doe" id="fullName" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" id="regEmail" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Min. 6 characters" id="regPassword" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat your password" id="confirmPassword" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" id="signUpBtn" class="btn btn-primary btn-full" style="margin-top:8px;">Sign Up</button>
        </form>

        <div class="auth-link">
            Already have an account? <a asp-action="Login">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
